<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <title>Title</title>
</head>
<body>
<div>
    <form method="post">
        <label>
            <input type="text" name="text" placeholder="Entry text">
        </label>
        <label>
            <input type="text" name="tag" placeholder="Entry tag">
        </label>
        <button type="submit">Add</button>
    </form>
</div>
<div>
    <form method="post" action="filter">
        <label>
            <input type="text" name="tag">
        </label>
        <button type="submit">Find</button>

    </form>
</div>
<div>Список Сообщений</div>
{{#messages}}
    <div>
        <b>{{id}}</b>
        <span>{{text}}</span>
        <i>{{tag}}</i>
    </div>
{{/messages}}


</body>
</html>